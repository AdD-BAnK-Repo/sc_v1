#!/bin/bash
# ============================================
# 🔔 XAlert - รันคำสั่ง + รายงาน Realtime ไป xdroid
# ============================================

CONFIG_FILE="$HOME/.notify_config"
[ -f "$CONFIG_FILE" ] && source "$CONFIG_FILE"

XDROID_API_KEY="${XDROID_API_KEY:-k-6516aa1ef0c9}"
TELEGRAM_CHAT_ID="${TELEGRAM_CHAT_ID:-6150548820}"

send_msg() {
    curl -s "http://xdroid.net/api/message?k=${XDROID_API_KEY}&t=$1&c=&u=${TELEGRAM_CHAT_ID}" > /dev/null 2>&1
}

if [ -z "$1" ]; then
    echo "Usage: xalert <command>"
    echo "Example: xalert 'apt list --upgradable'"
    exit 1
fi

COMMAND="$@"
START_TIME=$(date +%s)

# Step 1: แจ้งเริ่มต้น
send_msg "🔄 เริ่ม: $COMMAND"

# Step 2: รันคำสั่ง (timeout 60s)
OUTPUT=$(timeout 60 bash -c "$COMMAND" 2>&1)
EXIT_CODE=$?
DURATION=$(($(date +%s) - START_TIME))

# Step 3: ตัด output ให้กระชับ
OUTPUT_SHORT=$(echo "$OUTPUT" | head -15)
[ ${#OUTPUT} -gt 1500 ] && OUTPUT_SHORT="${OUTPUT_SHORT}..."

# Step 4: สรุปผล
[ $EXIT_CODE -eq 0 ] && STATUS="✅ เสร็จ (${DURATION}s)" || STATUS="❌ ผิดพลาด (${DURATION}s)"

# Step 5: ส่งผลลัพธ์
send_msg "${STATUS} | ${COMMAND}"$'\n'"${OUTPUT_SHORT}"

echo "✅ เสร็จ (${DURATION}s)"
exit $EXIT_CODE