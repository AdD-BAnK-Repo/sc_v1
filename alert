#!/bin/bash
# ============================================
# 🎙️ Alert - รันคำสั่ง + รายงาน Realtime ไป Telegram
# ============================================

CONFIG_FILE="$HOME/.notify_config"
[ -f "$CONFIG_FILE" ] && source "$CONFIG_FILE"

TELEGRAM_BOT_TOKEN="${TELEGRAM_BOT_TOKEN:-8591131313:AAELoKXEPS3LNGIzkCl9WALLWu2Ro839mHc}"
TELEGRAM_CHAT_ID="${TELEGRAM_CHAT_ID:-6150548820}"

send_msg() {
    curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
        -d "chat_id=${TELEGRAM_CHAT_ID}" \
        -d "text=$1" > /dev/null 2>&1
}

if [ -z "$1" ]; then
    echo "Usage: alert <command>"
    echo "Example: alert 'apt list --upgradable'"
    exit 1
fi

COMMAND="$@"
START_TIME=$(date +%s)

# Step 1: แจ้งเริ่มต้น
send_msg "🔄 เริ่ม: $COMMAND"

# Step 2: รันคำสั่ง (timeout 60s)
OUTPUT=$(timeout 60 bash -c "$COMMAND" 2>&1)
EXIT_CODE=$?
DURATION=$(($(date +%s) - START_TIME))

# Step 3: ตัด output ให้กระชับ (max 15 บรรทัด)
OUTPUT_SHORT=$(echo "$OUTPUT" | head -15)
if [ ${#OUTPUT} -gt 1500 ]; then
    OUTPUT_SHORT="${OUTPUT_SHORT}"$'\n...'
fi

# Step 4: สรุปผล
if [ $EXIT_CODE -eq 0 ]; then
    STATUS="✅ เสร็จ (${DURATION}s)"
else
    STATUS="❌ ผิดพลาด (${DURATION}s)"
fi

# Step 5: ส่งผลลัพธ์
FULL_MESSAGE="${STATUS}"$'\n'"CMD: ${COMMAND}"$'\n'"${OUTPUT_SHORT}"
send_msg "$FULL_MESSAGE"

echo "✅ เสร็จ (${DURATION}s)"
exit $EXIT_CODE