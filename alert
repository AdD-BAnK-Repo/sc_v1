#!/bin/bash
# ============================================
# 🎙️ Alert Script - รันคำสั่ง + แจ้งเตือน xdroid
# ============================================

XDROID_API_KEY="k-6516aa1ef0c9"
TELEGRAM_CHAT_ID="6150548820"

if [ -z "$1" ]; then
    echo "Usage: alert <command>"
    echo "Example: alert 'sudo apt update'"
    exit 1
fi

COMMAND="$@"
echo "🔄 กำลังรัน: $COMMAND"

# รันคำสั่ง
OUTPUT=$("$@" 2>&1)
EXIT_CODE=$?

# ตัด output ให้กระชับ
OUTPUT_SHORT=$(echo "$OUTPUT" | head -15)
if [ ${#OUTPUT} -gt 600 ]; then
    OUTPUT_SHORT="${OUTPUT_SHORT}"$'\n... (ตัดแล้ว)"
fi

# สรุปผล
if [ $EXIT_CODE -eq 0 ]; then
    STATUS="✅ เสร็จ"
else
    STATUS="❌ ผิดพลาด"
fi

# ส่งแจ้งเตือน xdroid
FULL_MESSAGE="${STATUS} | ${COMMAND}"
curl -s "http://xdroid.net/api/message?k=${XDROID_API_KEY}&t=${FULL_MESSAGE}&c=${OUTPUT_SHORT}&u=${TELEGRAM_CHAT_ID}" > /dev/null

echo "✅ เสร็จสิ้น (exit code: $EXIT_CODE)"
exit $EXIT_CODE