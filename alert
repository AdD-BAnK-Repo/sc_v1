#!/bin/bash
# ============================================
# 🎙️ Alert Script - รันคำสั่ง + ส่งผ่าน Telegram
# ============================================

TELEGRAM_BOT_TOKEN="8591131313:AAELoKXEPS3LNGIzkCl9WALLWu2Ro839mHc"
TELEGRAM_CHAT_ID="6150548820"

COMMAND="$*"

if [ -z "$COMMAND" ]; then
    echo "Usage: alert <command>"
    echo "Example: alert 'sudo apt update'"
    exit 1
fi

echo "🔄 กำลังรัน: $COMMAND"

# รันคำสั่ง
OUTPUT=$(eval "$COMMAND" 2>&1)
EXIT_CODE=$?

# ตัด output ให้กระชับ
OUTPUT_SHORT=$(echo "$OUTPUT" | head -15)
if [ ${#OUTPUT} -gt 600 ]; then
    OUTPUT_SHORT="${OUTPUT_SHORT}"$'\n'"... (ตัดแล้ว)"
fi

# สรุปผล
if [ $EXIT_CODE -eq 0 ]; then
    STATUS="✅ เสร็จ"
    SUMMARY="คำสั่งเสร็จสำเร็จ"
else
    STATUS="❌ ผิดพลาด"
    SUMMARY="คำสั่งมีข้อผิดพลาด"
fi

# ส่งผ่าน Telegram
FULL_MESSAGE="${STATUS}"$'\n'"Command: ${COMMAND}"$'\n'"Output:"$'\n'"${OUTPUT_SHORT}"

curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
    -d "chat_id=${TELEGRAM_CHAT_ID}" \
    -d "text=${FULL_MESSAGE}" \
    -d "parse_mode=Markdown" > /dev/null

echo "✅ เสร็จสิ้น (exit code: $EXIT_CODE)"
exit $EXIT_CODE