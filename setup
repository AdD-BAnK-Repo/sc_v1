#!/bin/bash
# ============================================
# 🔧 Setup - ตั้งค่า Scripts ครั้งแรก
# ============================================

CONFIG_FILE="$HOME/.notify_config"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "============================================"
echo "🔧 ตั้งค่า Notify Scripts"
echo "============================================"

# Check if already configured
if [ -f "$CONFIG_FILE" ]; then
    echo -e "${YELLOW}พบการตั้งค่าเดิม...${NC}"
    read -p "ต้องการตั้งค่าใหม่ไหม? (y/n): " REPLY
    if [ "$REPLY" != "y" ] && [ "$REPLY" != "Y" ]; then
        echo "ข้ามการตั้งค่า"
        exit 0
    fi
fi

echo ""

# Telegram Config
echo "📱 Telegram Config"
echo "-----------------------------------"
read -p "Bot Token: " BOT_TOKEN
read -p "Chat ID: " CHAT_ID
TELEGRAM_BOT_TOKEN=${BOT_TOKEN:-"8591131313:AAELoKXEPS3LNGIzkCl9WALLWu2Ro839mHc"}
TELEGRAM_CHAT_ID=${CHAT_ID:-"6150548820"}

echo ""

# Xdroid Config
echo "📳 Xdroid Config"
echo "-----------------------------------"
read -p "Xdroid API Key (k-xxxx): " XDROID_KEY
XDROID_API_KEY=${XDROID_KEY:-"k-6516aa1ef0c9"}

# Save config
cat > "$CONFIG_FILE" << EOF
TELEGRAM_BOT_TOKEN=$TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=$TELEGRAM_CHAT_ID
XDROID_API_KEY=$XDROID_API_KEY
EOF

chmod 600 "$CONFIG_FILE"
echo -e "${GREEN}✅ บันทึกการตั้งค่าแล้ว: $CONFIG_FILE${NC}"
echo ""

# Test connection
echo "🧪 ทดสอบการเชื่อมต่อ..."
curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
    -d "chat_id=${TELEGRAM_CHAT_ID}" \
    -d "text=✅ ทดสอบ: Notify Scripts พร้อมใช้งาน!" > /dev/null 2>&1

if [ $? -eq 0 ]; then
    echo -e "${GREEN}✅ Telegram: เชื่อมต่อสำเร็จ${NC}"
else
    echo -e "${RED}❌ Telegram: เชื่อมต่อไม่สำเร็จ${NC}"
fi

echo ""
echo "============================================"
echo "🎉 ตั้งค่าเสร็จสิ้น!"
echo "============================================"
echo ""
echo "วิธีใช้:"
echo "  notify 'ข้อความ'      # -> Telegram"
echo "  xnotify 'ข้อความ'     # -> xdroid"
echo "  alert 'คำสั่ง'         # -> Telegram realtime"
echo "  xalert 'คำสั่ง'        # -> xdroid realtime"