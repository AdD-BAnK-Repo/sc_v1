#!/bin/bash
# ============================================
# 🔧 Setup - ตั้งค่า + ติดตั้ง Scripts อัตโนมัติ
# ============================================

INSTALL_DIR="/usr/local/bin"
CONFIG_FILE="$HOME/.notify_config"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "============================================"
echo "🔧 ติดตั้ง Notify Scripts"
echo "============================================"

# Check/install scripts
echo ""
echo "📥 กำลังโหลด Scripts..."
for s in setup notify xnotify alert xalert; do
    sudo wget -q -O "$INSTALL_DIR/$s" "https://raw.githubusercontent.com/PRIVATE-OBSIDIAN-NOTE/sc_v1/refs/heads/main/$s"
    sudo chmod +x "$INSTALL_DIR/$s"
    echo "  ✅ $s"
done

echo ""

# Check if config exists
if [ -f "$CONFIG_FILE" ]; then
    echo -e "${GREEN}✅ พบการตั้งค่าเดิม${NC}"
    cat "$CONFIG_FILE"
    echo ""
    read -p "ต้องการตั้งค่าใหม่ไหม? (y/n): " REPLY
    if [ "$REPLY" != "y" ] && [ "$REPLY" != "Y" ]; then
        echo -e "${GREEN}🎉 เสร็จสิ้น!${NC}"
        exit 0
    fi
fi

echo ""
echo "============================================"
echo "📱 ตั้งค่า (ครั้งแรก)"
echo "============================================"
echo ""

# Telegram Config
echo "📱 Telegram Config"
echo "-----------------------------------"
read -p "Bot Token [ ENTER = default ]: " BOT_TOKEN
read -p "Chat ID [ ENTER = default ]: " CHAT_ID

TELEGRAM_BOT_TOKEN=${BOT_TOKEN:-8591131313:AAELoKXEPS3LNGIzkCl9WALLWu2Ro839mHc}
TELEGRAM_CHAT_ID=${CHAT_ID:-6150548820}

echo ""

# Xdroid Config
echo "📳 Xdroid Config"
echo "-----------------------------------"
read -p "Xdroid API Key [ ENTER = default ]: " XDROID_KEY
XDROID_API_KEY=${XDROID_KEY:-k-6516aa1ef0c9}

# Save config
cat > "$CONFIG_FILE" << EOF
TELEGRAM_BOT_TOKEN=$TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=$TELEGRAM_CHAT_ID
XDROID_API_KEY=$XDROID_API_KEY
EOF

chmod 600 "$CONFIG_FILE"
echo ""
echo -e "${GREEN}✅ บันทึกการตั้งค่าแล้ว${NC}"

# Test connection
echo ""
echo "🧪 ทดสอบส่งข้อความ..."
curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
    -d "chat_id=${TELEGRAM_CHAT_ID}" \
    -d "text=✅ Notify Scripts พร้อมใช้งาน!" > /dev/null 2>&1

if [ $? -eq 0 ]; then
    echo -e "${GREEN}✅ Telegram: สำเร็จ${NC}"
else
    echo -e "${RED}❌ Telegram: ไม่สำเร็จ (ตรวจสอบ Bot Token)${NC}"
fi

echo ""
echo "============================================"
echo -e "${GREEN}🎉 ติดตั้งเสร็จสิ้น!${NC}"
echo "============================================"
echo ""
echo "วิธีใช้:"
echo "  notify 'ข้อความ'      # -> Telegram"
echo "  xnotify 'ข้อความ'     # -> xdroid"
echo "  alert 'คำสั่ง'         # -> Telegram realtime"
echo "  xalert 'คำสั่ง'        # -> xdroid realtime"