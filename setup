#!/bin/bash
# ============================================
# 🔧 Setup - ติดตั้ง Notify Scripts
# ============================================

INSTALL_DIR="/usr/local/bin"
CONFIG_FILE="$HOME/.notify_config"

# Parse arguments
TEST_MODE=false
XDROID_KEY=""
BOT_TOKEN=""
CHAT_ID=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --test|-t)
            TEST_MODE=true
            shift
            ;;
        --xdroid|-x)
            XDROID_KEY="$2"
            shift 2
            ;;
        --bot|-b)
            BOT_TOKEN="$2"
            shift 2
            ;;
        --chat|-c)
            CHAT_ID="$2"
            shift 2
            ;;
        *)
            shift
            ;;
    esac
done

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "============================================"
echo "🔧 ติดตั้ง Notify Scripts"
echo "============================================"

# Install scripts
echo ""
echo "📥 กำลังโหลด Scripts..."
for s in setup notify xnotify alert xalert; do
    sudo wget -q -O "$INSTALL_DIR/$s" "https://raw.githubusercontent.com/PRIVATE-OBSIDIAN-NOTE/sc_v1/refs/heads/main/$s"
    sudo chmod +x "$INSTALL_DIR/$s"
    echo "  ✅ $s"
done

echo ""

# Check if already configured
if [ -f "$CONFIG_FILE" ] && [ "$TEST_MODE" = false ]; then
    echo -e "${YELLOW}⚠️ พบการตั้งค่าเดิม${NC}"
    read -p "ต้องการตั้งค่าใหม่ไหม? (y/n): " REPLY
    if [ "$REPLY" != "y" ] && [ "$REPLY" != "Y" ]; then
        echo -e "${GREEN}🎉 เสร็จสิ้น!${NC}"
        exit 0
    fi
fi

# Set up credentials
if [ "$TEST_MODE" = true ]; then
    # Test mode - use defaults
    TELEGRAM_BOT_TOKEN="8591131313:AAELoKXEPS3LNGIzkCl9WALLWu2Ro839mHc"
    TELEGRAM_CHAT_ID="6150548820"
    XDROID_API_KEY="k-6516aa1ef0c9"
    echo -e "${YELLOW}📋 Test Mode: ใช้ค่าเริ่มต้น${NC}"
else
    # Real mode - require input
    echo ""
    echo "============================================"
    echo "📱 ตั้งค่า (กรอกเอง)"
    echo "============================================"
    echo ""
    
    echo "📱 Telegram:"
    read -p "  Bot Token: " BOT_TOKEN
    read -p "  Chat ID: " CHAT_ID
    
    echo ""
    echo "📳 Xdroid:"
    read -p "  API Key (k-xxxx): " XDROID_KEY
    
    TELEGRAM_BOT_TOKEN=${BOT_TOKEN}
    TELEGRAM_CHAT_ID=${CHAT_ID:-6150548820}
    XDROID_API_KEY=${XDROID_KEY}
fi

# Save config
cat > "$CONFIG_FILE" << EOF
TELEGRAM_BOT_TOKEN=$TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=$TELEGRAM_CHAT_ID
XDROID_API_KEY=$XDROID_API_KEY
EOF

chmod 600 "$CONFIG_FILE"
echo ""
echo -e "${GREEN}✅ บันทึกการตั้งค่าแล้ว${NC}"

# Test send
echo ""
curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
    -d "chat_id=${TELEGRAM_CHAT_ID}" \
    -d "text=✅ Notify Scripts พร้อมใช้งาน!" > /dev/null 2>&1

if [ $? -eq 0 ]; then
    echo -e "${GREEN}✅ Telegram: สำเร็จ${NC}"
else
    echo -e "${RED}❌ Telegram: ตรวจสอบ Bot Token${NC}"
fi

echo ""
echo "============================================"
echo -e "${GREEN}🎉 เสร็จสิ้น!${NC}"
echo "============================================"
echo ""
echo "วิธีใช้:"
echo "  notify 'ข้อความ'      # -> Telegram"
echo "  xnotify 'ข้อความ'     # -> xdroid"
echo "  alert 'คำสั่ง'         # -> Telegram realtime"
echo "  xalert 'คำสั่ง'        # -> xdroid realtime"