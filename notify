#!/bin/bash
# ============================================
# 📱 Notify Script - ส่งแจ้งเตือนไป Telegram
# ============================================

TELEGRAM_BOT_TOKEN="8591131313:AAELoKXEPS3LNGIzkCl9WALLWu2Ro839mHc"
TELEGRAM_CHAT_ID="6150548820"

MESSAGE="$*"

if [ -z "$MESSAGE" ]; then
    echo "Usage: notify <ข้อความ>"
    echo "Example: notify 'Server ทำงานปกติ'"
    exit 1
fi

# ส่ง via Telegram Bot
curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
    -d "chat_id=${TELEGRAM_CHAT_ID}" \
    -d "text=${MESSAGE}" \
    -d "parse_mode=Markdown" > /dev/null

echo "✅ ส่งแจ้งเตือน: $MESSAGE"